{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.agents/hooks/guard-openshift-command.py\"",
            "timeout": 15,
            "statusMessage": "Checking OpenShift cluster guard"
          }
        ]
      }
    ]
  }
}
