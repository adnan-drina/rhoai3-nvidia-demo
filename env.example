# Git repository for Argo CD
GIT_REPO_URL=https://github.com/adnan-drina/rhoai3-nvidia-demo.git
GIT_REPO_BRANCH=main

# Safety guard: scripts refuse live OpenShift work unless the current API server
# contains this substring. Use a unique cluster id or full API hostname.
RHOAI_EXPECTED_API_SERVER=
# RHOAI_ALLOW_UNGUARDED_CLUSTER=false
# RHOAI_OC_REQUEST_TIMEOUT=10s

# Optional project-local kubeconfig. Use an absolute path so scripts and hooks
# resolve it consistently from any working directory. Never commit kubeconfigs;
# /tmp/ and *.kubeconfig are ignored.
# KUBECONFIG=/absolute/path/to/rhoai3-nvidia-demo/tmp/current-cluster.kubeconfig

# AWS credentials for the sandbox account (from the RHDP environment details).
# Used for AWS-side work outside the cluster: GPU capacity checks
# (describe-instance-type-offerings), subnet creation in additional AZs, and
# EC2 Capacity Block reservations. Never commit real values; .env is ignored.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-2

# Stage 110 demo user passwords (setup-access.sh). If unset, random passwords are
# generated and appended here. Set them to use fixed demo credentials instead.
# AI_ADMIN_PASSWORD=
# AI_DEVELOPER_PASSWORD=
# AI_RESEARCHER_PASSWORD=

# Stage 210 model-serving defaults. Override only when the demo model, registry,
# namespace, queue, or hardware profile changes.
# MODEL_REGISTRY_NAMESPACE=rhoai-model-registries
# MODEL_REGISTRY_NAME=demo-registry
# RHOAI_MODEL_NAMESPACE=demo-sandbox

# Stage 220 MaaS defaults. Provider keys and database passwords stay local and
# are converted into OpenShift Secrets by deploy scripts.
# RHOAI_MAAS_NAMESPACE=models-as-a-service

# HuggingFace token (reserved for model/data workflows)
# HF_TOKEN=

# OpenAI provider key for external MaaS models.
# OPENAI_API_KEY=

# NVIDIA API key (required for NGC model deployment and hosted NIM access).
# Get your API key at: https://org.ngc.nvidia.com/setup/api-key
# Sign up for NIM access at: https://build.nvidia.com/
NVIDIA_API_KEY=
# NVIDIA_NGC_API_KEY=

# Tavily API key (needed for AI-Q web search functionality).
# Sign up at: https://tavily.com/
TAVILY_API_KEY=

# Serper API key (for academic paper search via Google Scholar).
# Sign up at: https://serper.dev/
SERPER_API_KEY=

# Stage 310 NVIDIA NIM defaults.
# RHOAI_STAGE310_NAMESPACE=nvidia-nim-agents
# RHOAI_STAGE310_NIM_SECRET=nvidia-nim-api-key

# Stage 320 multi-agent research defaults.
# RHOAI_STAGE320_NAMESPACE=multi-agent-research
# RHOAI_STAGE320_ORCHESTRATOR_SECRET=agent-orchestrator-config
